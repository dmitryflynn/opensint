# ─────────────────────────────────────────────────────────────
# OpenSINT configuration — copy this file to `.env` and fill in
# the keys for the data sources you want to enable. Every module
# works without a key using free/public sources; adding a key
# unlocks richer data and higher rate limits.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
# Comma-separated list of allowed CORS origins (frontend URLs).
CORS_ORIGIN=http://localhost:5173

# ── Optional API keys (all modules degrade gracefully without them) ──

# HaveIBeenPwned — breach exposure lookups for emails.
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# VirusTotal — file & hash reputation across 70+ AV engines.
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB — IP reputation / abuse confidence score.
# https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# Shodan — open ports / exposed services for an IP.
# https://account.shodan.io/
SHODAN_API_KEY=

# IPinfo — richer IP geolocation & ASN (falls back to free ip-api.com).
# https://ipinfo.io/account/token
IPINFO_TOKEN=
